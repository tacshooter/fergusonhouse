generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parent    Folder?  @relation("SubFolders", fields: [parentId], references: [id])
  children  Folder[] @relation("SubFolders")
  posts     Post[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  folderId  String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  folder    Folder   @relation(fields: [folderId], references: [id])
}

model StaticPage {
  id        String   @id
  title     String
  subtitle  String
  content   String
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BlogSchedule {
  id        String   @id @default(cuid())
  date      DateTime
  topic     String
  slug      String?
  status    String   @default("PENDING") // PENDING, SCHEDULED, PUBLISHED
  week_no   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

